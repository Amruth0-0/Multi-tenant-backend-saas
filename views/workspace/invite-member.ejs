<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Invite Member | TenantFlow</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    data-protected="true"
    class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white min-h-screen flex flex-col"
  >
    <!-- NAVBAR -->
    <nav class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md">
      <div
        class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4"
      >
        <div class="flex items-center gap-3">
          <img src="/assets/Logo.png" class="h-8" />
          <span class="text-lg font-semibold">TenantFlow</span>
        </div>

        <div class="flex gap-6 text-sm text-slate-400">
          <a href="/dashboard">Dashboard</a>
          <a href="/projects">Projects</a>
          <a href="/workspace/members">Members</a>
          <button id="logoutBtn">Logout</button>
        </div>
      </div>
    </nav>

    <!-- MAIN -->
    <main class="flex-1 flex items-center justify-center px-6 py-12">
      <div
        class="w-full max-w-lg bg-slate-800/60 border border-slate-700 rounded-3xl p-10"
      >
        <!-- HEADER -->
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold">Invite Member</h1>
          <p class="text-slate-400 text-sm mt-2">
            Invite a new member to your workspace
          </p>
        </div>

        <form id="inviteForm" class="space-y-6">
          <!-- EMAIL -->
          <div>
            <label class="block text-sm text-slate-300 mb-2"
              >Member Email</label
            >

            <input
              type="email"
              id="email"
              required
              placeholder="john@email.com"
              class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm focus:ring-2 focus:ring-blue-600"
            />
          </div>

          <!-- ROLE -->
          <div>
            <label class="block text-sm text-slate-300 mb-2">Role</label>
            <select
              id="role"
              class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm"
            >
              <option value="member">Member</option>
              <option value="admin">Admin</option>
            </select>
          </div>

          <!-- BUTTON -->
          <button
            type="submit"
            id="inviteBtn"
            class="w-full bg-blue-600 hover:bg-blue-700 py-3 rounded-xl text-sm font-medium"
          >
            Send Invitation
          </button>
        </form>
      </div>
    </main>

    <!-- FOOTER -->
    <footer
      class="border-t border-slate-800 py-6 text-center text-sm text-slate-500"
    >
      © <%= new Date().getFullYear() %> TenantFlow
    </footer>

    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/members.js"></script>
  </body>
</html>
