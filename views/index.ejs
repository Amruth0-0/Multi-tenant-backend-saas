<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>TenantFlow | Multi-Tenant SaaS</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white min-h-screen">

  <!-- NAVBAR -->
  <nav class="flex justify-between items-center px-10 py-6">
    <div class="flex items-center gap-3">
    <img 
      src="../assets/Logo.png" 
      alt="TenantFlow Logo"
      class=" h-9 w-auto object-contain"
    />
     <span class="text-xl font-semibold tracking-wide">TenantFlow</span>
    </div>

    <div class="flex items-center gap-8 text-sm text-slate-300">
      <a href="#features" class="hover:text-white transition">How it works</a>
      <a href="/login" class="hover:text-white transition">Login</a>
      <a href="/register"
        class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-white transition shadow-md">
        Get Started
      </a>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <section class="text-center mt-20 px-4">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
      Manage your team in one secure workspace
    </h1>
    <p class="text-slate-400 max-w-2xl mx-auto mb-8">
      A multi-tenant SaaS platform for teams to collaborate, manage tasks,
      and scale securely.
    </p>

    <div class="flex justify-center gap-4">
      <a href="/register"
        class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-lg font-medium transition shadow-lg">
        Create Workspace
      </a>
      <a href="/login"
        class="border border-slate-600 hover:border-slate-400 px-6 py-3 rounded-lg transition">
        Login
      </a>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="mt-24 px-6">
    <h2 class="text-center text-2xl font-semibold mb-12">
      Core Features
    </h2>

    <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">

      <div class="bg-slate-800/60 backdrop-blur-md p-6 rounded-xl border border-slate-700 hover:border-blue-500 transition shadow-lg">
        <h3 class="font-semibold mb-2">🔐 Secure authentication & roles</h3>
        <p class="text-slate-400 text-sm">
          JWT-based authentication with role-based access control.
        </p>
      </div>

      <div class="bg-slate-800/60 backdrop-blur-md p-6 rounded-xl border border-slate-700 hover:border-blue-500 transition shadow-lg">
        <h3 class="font-semibold mb-2">🏢 Organization-based workspaces</h3>
        <p class="text-slate-400 text-sm">
          Each tenant operates in an isolated workspace.
        </p>
      </div>

      <div class="bg-slate-800/60 backdrop-blur-md p-6 rounded-xl border border-slate-700 hover:border-blue-500 transition shadow-lg">
        <h3 class="font-semibold mb-2">📁 Project & task management</h3>
        <p class="text-slate-400 text-sm">
          Create projects, assign tasks, and collaborate efficiently.
        </p>
      </div>

      <div class="bg-slate-800/60 backdrop-blur-md p-6 rounded-xl border border-slate-700 hover:border-blue-500 transition shadow-lg">
        <h3 class="font-semibold mb-2">🛡 Tenant-isolated data</h3>
        <p class="text-slate-400 text-sm">
          Strict workspace-level data isolation for maximum security.
        </p>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="mt-24 px-6 max-w-4xl mx-auto">
    <h2 class="text-center text-2xl font-semibold mb-8">
      Frequently Asked Questions
    </h2>

    <div class="space-y-4">

      <details class="bg-slate-800/60 border border-slate-700 rounded-lg p-4">
        <summary class="cursor-pointer font-medium">
          What is a workspace?
        </summary>
        <p class="text-slate-400 text-sm mt-3">
          A workspace represents your organization on the platform.
          All users, projects, and data belong to it.
        </p>
      </details>

      <details class="bg-slate-800/60 border border-slate-700 rounded-lg p-4">
        <summary class="cursor-pointer font-medium">
          How does data isolation work?
        </summary>
        <p class="text-slate-400 text-sm mt-3">
          Every request is scoped by workspaceId to ensure strict tenant separation.
        </p>
      </details>

      <details class="bg-slate-800/60 border border-slate-700 rounded-lg p-4">
        <summary class="cursor-pointer font-medium">
          Can I manage multiple workspaces?
        </summary>
        <p class="text-slate-400 text-sm mt-3">
          Yes. You can create or join multiple isolated workspaces.
        </p>
      </details>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="mt-24 border-t border-slate-800 py-10 px-10 text-sm text-slate-400">
    <div class="flex flex-col md:flex-row justify-between max-w-6xl mx-auto">

      <div>
        <h4 class="font-semibold text-white mb-2">TenantFlow</h4>
        <p>Secure multi-tenant SaaS architecture built for learning and scale.</p>
      </div>

      <div class="mt-6 md:mt-0 space-y-2">
        <h5 class="font-semibold text-white">Legal</h5>
        <p>Privacy Policy</p>
        <p>Terms & Conditions</p>
      </div>

    </div>

    <div class="text-center text-xs mt-8 text-slate-500">
      © <%= new Date().getFullYear() %> TenantFlow. All Rights Reserved.
    </div>
  </footer>

</body>
</html>
