<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Projects | TenantFlow</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body data-protected="true"
  class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white min-h-screen flex flex-col"
>

<!-- NAVBAR -->
<nav class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">

    <!-- Logo -->
    <div class="flex items-center gap-3">
      <img src="/assets/Logo.png" class="h-8 w-auto" />
      <span class="text-lg font-semibold tracking-wide">TenantFlow</span>
    </div>

    <!-- Nav Links -->
    <div class="flex items-center gap-6 text-sm text-slate-400">

      <a href="/dashboard" class="hover:text-white transition">Dashboard</a>

      <a href="/projects" class="text-white">Projects</a>

      <a href="/workspace/members" class="hover:text-white transition">Members</a>

      <button id="logoutBtn" class="hover:text-white transition">
        Logout
      </button>

    </div>
  </div>
</nav>



<!-- MAIN -->
<main class="flex-1 px-6 py-10 max-w-7xl mx-auto w-full">


  <!-- HEADER -->
  <div class="flex justify-between items-center mb-8">

    <div>
      <h1 class="text-3xl font-bold">Projects</h1>
      <p class="text-slate-400 text-sm mt-1">
        Manage and track all workspace projects
      </p>
    </div>

    <a href="/projects/create"
      class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm transition">
      + Create Project
    </a>

  </div>


  <div id="projectList" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

    <% if (projects?.length) { %>
      <% projects.forEach(project => { %>

        <!-- CARD -->
        <div class="bg-slate-800/60 border border-slate-700 rounded-2xl p-6 hover:border-blue-500 transition">

          <div class="flex justify-between items-center mb-4">

            <h2 class="font-semibold text-lg">
              <%= project.name %>
            </h2>

            <span class="text-xs text-slate-400">
              <%= project.status || "Active" %>
            </span>

          </div>


          <p class="text-slate-400 text-sm mb-4">
            <%= project.description || "No description provided." %>
          </p>


          <div class="flex justify-between items-center text-sm">

            <a href="/projects/<%= project._id %>"
              class="text-blue-400 hover:text-blue-300">
              View Project
            </a>

            <span class="text-slate-500 text-xs">
              Created by <%= project.createdBy || "User" %>
            </span>

          </div>

        </div>

      <% }) %>
    <% } else { %>

      <!-- EMPTY STATE -->
      <div class="col-span-full text-center py-16">

        <p class="text-slate-400 mb-4">
          No projects created yet
        </p>

        <a href="/projects/create"
          class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm transition">
          Create your first project
        </a>

      </div>

    <% } %>

  </div>

</main>



<!-- FOOTER -->
<footer class="border-t border-slate-800 py-6 text-center text-sm text-slate-500">
  © <%= new Date().getFullYear() %> TenantFlow. All Rights Reserved.
</footer>


<script src="/js/api.js"></script>
<script src="/js/auth.js"></script>
<script src="/js/projects.js"></script>

</body>
</html>